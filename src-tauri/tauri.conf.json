{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "clippy",
  "version": "1.6.8",
  "identifier": "clippy",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true,
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "clippy",
        "alwaysOnTop": true,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "url": "pages/index.html"
      }
    ]
  },
  "bundle": {
    "active": true,
    "resources": [
      "models/*"
    ],
    "license": "MIT",
    "shortDescription": "clipboard manager",
    "longDescription": "clipboard manager built with Rust & Typescript",
    "category": "Utility",
    "publisher": "0-don",
    "copyright": "2026 0-don",
    "targets": [
      "app",
      "deb",
      "rpm",
      "dmg",
      "appimage",
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [],
        "files": {
          "/usr/share/metainfo/io.github._0_don.clippy.metainfo.xml": "../.github/flathub/io.github._0_don.clippy.metainfo.xml"
        }
      },
      "rpm": {
        "depends": []
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.13",
      "exceptionDomain": "",
      "frameworks": []
    },
    "windows": {
      "nsis": {
        "installerHooks": "installer-hooks.nsh",
        "languages": [
          "English",
          "SimpChinese",
          "Spanish",
          "French",
          "Arabic",
          "Russian",
          "Japanese",
          "German",
          "Korean",
          "Turkish",
          "Italian",
          "Dutch"
        ]
      }
    }
  },
  "plugins": {
    "oauth": {
      "google": {
        "clientId": "%TAURI_GOOGLE_CLIENT_ID%",
        "clientSecret": "%TAURI_GOOGLE_CLIENT_SECRET%"
      }
    }
  }
}
