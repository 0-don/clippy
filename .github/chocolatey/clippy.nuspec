<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>clippy-clipboard</id>
    <version>{{VERSION}}</version>
    <title>Clippy</title>
    <authors>0-don</authors>
    <owners>0-don</owners>
    <projectUrl>https://github.com/0-don/clippy</projectUrl>
    <projectSourceUrl>https://github.com/0-don/clippy</projectSourceUrl>
    <packageSourceUrl>https://github.com/0-don/clippy/tree/main/.github/chocolatey</packageSourceUrl>
    <docsUrl>https://github.com/0-don/clippy/blob/main/README.md</docsUrl>
